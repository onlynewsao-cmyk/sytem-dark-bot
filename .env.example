# DARK System WhatsApp Bot
# Copie para .env localmente. No Render, configure como Environment Variables.

BOT_NAME="DARK System"
OWNER_NAME="Dark Net"
OWNER_NUMBER="244945280380"
BOT_NUMBER="244949926074"

# MongoDB Atlas recomendado no Render Free
MONGODB_URI="mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/dark-system?retryWrites=true&w=majority"

# Prefixos globais separados por vírgula. Cada grupo também pode configurar os seus.
DEFAULT_PREFIXES="!,.,/,#"

# Render / Uptime
PORT="3000"
PUBLIC_BASE_URL=""
QR_WEB_ENABLED="true"
QR_WEB_KEY="troque-esta-chave"

# Conexão por código de pareamento. Por padrão usa BOT_NUMBER.
USE_PAIRING_CODE="true"
PAIRING_NUMBER="244949926074"

# No Render Free, o bot só atende grupos onde ele é admin.
RENDER_FREE_REQUIRES_BOT_ADMIN="true"

# Limites
MAX_MEDIA_MB="15"
DIRECT_DOWNLOAD_MAX_MB="20"
TZ="Africa/Luanda"
